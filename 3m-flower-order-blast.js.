const fs = require("fs");
const path = require("path");

// ======================================================
// CONFIG
// ======================================================

const BASE_URL = "https://brightlane.github.io/FtdFlowers/";
const OUTPUT_DIR = path.join(__dirname, "output", "flower-pages");

// Ensure output folder exists
if (!fs.existsSync(OUTPUT_DIR)) {
  fs.mkdirSync(OUTPUT_DIR, { recursive: true });
}

// ======================================================
// DATA SETS
// ======================================================

const FLOWERS = [
  "roses", "tulips", "lilies", "peonies", "orchids",
  "sunflowers", "daisies", "carnations", "bouquet"
];

const OCCASIONS = [
  "mothers-day", "anniversary", "birthday",
  "get-well", "sympathy", "wedding"
];

const ADJECTIVES = [
  "same-day", "premium", "luxury", "fresh",
  "express", "hand-delivered", "local"
];

const PERSONAS = [
  "busy-mom", "student", "office-worker", "nurse", "doctor"
];

// ======================================================
// SLUG
// ======================================================

const SLUG = "same-day-roses-order-flowers-online-new-york";

// ======================================================
// HTML GENERATOR
// ======================================================

function generate5kHtml(slug) {
  const parts = slug.split("-");

  let flower = "roses";
  let occasion = "order-flowers-online";
  let city = "new-york";

  for (const p of parts) {
    if (FLOWERS.includes(p)) flower = p;
    if (OCCASIONS.includes(p)) occasion = p;
    if (p === "new" || p === "york") city = "new-york";
  }

  const cityWords = city.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase());
  const flowerWords = flower.replace(/\b\w/g, c => c.toUpperCase());
  const occWords = occasion.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase());

  const title = `Same Day ${flowerWords} Order Flowers Online ${cityWords}`;

  const intro = `
<section>
  <h1>${title}</h1>
  <p>
    Order ${flowerWords} online in ${cityWords} for ${occWords}.
    This page explains how to send flowers, buy bouquets, and arrange same-day delivery
    using local florist networks in ${cityWords}.
  </p>
</section>
`;

  const body = `
<section>
  <h2>Flower Delivery in ${cityWords}</h2>
  <p>
    Customers in ${cityWords} frequently order ${flowerWords} for birthdays, anniversaries,
    and sympathy occasions. Same-day delivery ensures flowers arrive fresh and on time.
  </p>

  <p>
    Florists prepare arrangements locally, ensuring high quality and fast delivery across
    ${cityWords} neighborhoods.
  </p>
</section>
`;

  const fullHtml = `
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>${title}</title>
  <meta name="description" content="Order ${flowerWords} online in ${cityWords} with same-day delivery from local florists.">
</head>
<body>
  ${intro}
  ${body}
</body>
</html>
`;

  return fullHtml;
}

// ======================================================
// WRITE FILE
// ======================================================

const html = generate5kHtml(SLUG);

const filePath = path.join(OUTPUT_DIR, `${SLUG}.html`);
fs.writeFileSync(filePath, html);

console.log("✅ PAGE CREATED:", filePath);
console.log("🌐 READY URL:", BASE_URL + SLUG + ".html");
